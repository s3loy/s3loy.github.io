---
import type { MarkdownHeading } from 'astro'
import TOCHeading from '~/components/TableOfContentsHeading.astro'

interface Props {
  headings: MarkdownHeading[]
}

const { headings } = Astro.props

const filteredHeadings = headings.filter(({ depth }) => depth >= 2 && depth <= 3)
---

<details
  open
  class="toc relative md:mx-2 xl:mx-0 text-foreground/90 text-sm bg-foreground/5 xl:bg-transparent px-8 xl:pr-0 py-6 mt-5 xl:mt-0 xl:w-full rounded-xl border-3 xl:border-none border-accent/10 xl:sticky xl:top-10 xl:basis-[274px] 2xl:basis-[320px] xl:order-2 xl:shrink-0 xl:opacity-90"
>
  <summary
    class="list-none marker:hidden marker:content-[''] before:content-['>'] before:text-accent before:font-semibold before:absolute before:left-3 cursor-pointer"
    >Table of Contents</summary
  >
  <nav class="w-full text-sm xl:-ml-1 xl:max-h-[calc(100vh-8rem)] xl:overflow-y-auto">
    <ul class="mt-4 flex flex-col max-w-full">
      {filteredHeadings.map((heading) => <TOCHeading heading={heading} />)}
    </ul>
  </nav>
</details>

<script>
  function getDocumentOffsetTop(el: HTMLElement): number {
    let top = 0
    let cur: HTMLElement | null = el
    while (cur) {
      top += cur.offsetTop
      cur = cur.offsetParent as HTMLElement | null
    }
    return top
  }

  const anchors = Array.from(document.querySelectorAll<HTMLElement>('h2[id], h3[id]'))
  const links = Array.from(document.querySelectorAll<HTMLElement>('details.toc > nav > ul > li'))
  const tocNav = document.querySelector<HTMLElement>('details.toc > nav')

  if (anchors.length === links.length && anchors.length > 0) {
    let activeIndex = -1

    function updateTOC() {
      const scrollTop = window.scrollY
      let newIndex = -1
      for (let i = anchors.length - 1; i >= 0; i--) {
        if (scrollTop >= getDocumentOffsetTop(anchors[i]) - 100) {
          newIndex = i
          break
        }
      }
      if (newIndex === activeIndex) return
      activeIndex = newIndex
      links.forEach((link, i) => {
        if (i === newIndex) {
          link.classList.add('active-heading')
          // Scroll active item into view within the TOC nav
          if (tocNav) {
            const linkTop = link.offsetTop
            const linkBottom = linkTop + link.offsetHeight
            const navScrollTop = tocNav.scrollTop
            const navHeight = tocNav.clientHeight
            if (linkTop < navScrollTop) {
              tocNav.scrollTo({ top: linkTop - 8, behavior: 'smooth' })
            } else if (linkBottom > navScrollTop + navHeight) {
              tocNav.scrollTo({ top: linkBottom - navHeight + 8, behavior: 'smooth' })
            }
          }
        } else {
          link.classList.remove('active-heading')
        }
      })
    }

    window.addEventListener('scroll', updateTOC, { passive: true })
    updateTOC()
  }
</script>

<style>
  details[open] summary:before {
    transform: rotate(90deg);
  }
</style>
