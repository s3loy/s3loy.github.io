  },
]
---

<Layout title={`友情链接 - ${siteConfig.title}`} description={siteConfig.description}>
  <main>
    <div class="divide-y dark:divide-zinc-800">
      {
        friends.map((friend) => (
          <a
            href={friend.url}
            target="_blank"
            rel="noopener noreferrer"
            class="group flex items-center gap-4 py-4 transition-opacity hover:opacity-70"
          >
            <img
              src={friend.avatar}
              alt={friend.name}
              class="size-10 rounded-full shrink-0"
            />
            <div class="min-w-0">
              <p class="font-medium text-zinc-900 dark:text-zinc-100">{friend.name}</p>
              <p class="text-sm text-zinc-500 dark:text-zinc-400 truncate">
                {friend.description}
              </p>
            </div>
          </a>
        ))
      }
    </div>
  </main>
</Layout>
